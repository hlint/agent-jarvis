{
  "name": "turbo-forge",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "check-types": "turbo run check-types",
    "ci": "bun install --frozen-lockfile",
    "compile": "turbo run compile:frontend compile:server",
    "dev": "turbo run dev",
    "dev:reset": "rm -rf ./runtime && bun dev",
    "format": "NODE_NO_WARNINGS=1 sort-package-json && turbo run format",
    "start": "turbo run start"
  },
  "dependencies": {
    "dayjs": "^1.11.19",
    "es-toolkit": "^1.44.0",
    "nanoid": "^5.1.6",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.8",
    "@total-typescript/ts-reset": "^0.6.1",
    "prettier": "^3.7.4",
    "sort-package-json": "^3.6.0",
    "turbo": "^2.6.3",
    "typescript": "5.9.2"
  },
  "packageManager": "bun@1.3.4",
  "engines": {
    "node": ">=18"
  }
}
